---
import { getCollection } from 'astro:content';
import { useTranslations, localeMeta, type Locale } from '../i18n';
import Nav from './Nav.astro';
import AITranslatedBadge from './AITranslatedBadge.astro';

interface Props {
  lang: Locale;
  pathname: string;
}

const { lang, pathname } = Astro.props;
const t = useTranslations(lang);

const posts = (await getCollection('blog', (p) => p.id.startsWith(`${lang}/`))).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const allTags = Array.from(new Set(posts.flatMap(p => p.data.tags))).sort();
const fmtDate = (d: Date) =>
  d.toLocaleDateString(localeMeta[lang].dateLocale, { day: '2-digit', month: 'short', year: 'numeric' });

const homeBase = lang === 'en' ? '/' : `/${lang}/`;
const blogPath = lang === 'en' ? '/blog/' : `/${lang}/blog/`;
const stripLocale = (id: string) => id.replace(new RegExp(`^${lang}/`), '');

const showAIBadge = posts.some(p => p.data.ai_translated);
---

<Nav lang={lang} pathname={pathname} startScrolled active="blog" homeBase={homeBase} blogPath={blogPath} />

<main class="blog-page">
  <div class="container">
    <header class="blog-header">
      <div class="section-num">// {t('nav.blog')}</div>
      <h1 class="blog-h1">{t('blog.tagline_title')}</h1>
      <p class="blog-sub">{t('blog.tagline_sub')}</p>
    </header>

    <div class="search-wrap">
      <input id="blog-search" type="search" placeholder={t('blog.search_placeholder')} autocomplete="off" />
      <div class="tag-filters" id="tag-filters">
        <button class="tag-pill active" data-tag="__all__">{t('blog.tag_all')}</button>
        {allTags.map(tag => (
          <button class="tag-pill" data-tag={tag}>#{tag}</button>
        ))}
      </div>
    </div>

    <div class="post-list" id="post-list">
      {posts.map(p => {
        const slug = stripLocale(p.id);
        return (
          <a
            href={`${blogPath}${slug}/`}
            class="post-card"
            data-title={p.data.title.toLowerCase()}
            data-desc={(p.data.description || '').toLowerCase()}
            data-tags={p.data.tags.join(',').toLowerCase()}
          >
            {p.data.img && <div class="post-img-wrap"><img src={p.data.img} alt="" loading="lazy" onerror="if(!this.dataset.f){this.dataset.f='1';this.src='/blog/fallback.svg';}" /></div>}
            <div class="post-body">
              <div class="post-meta">{fmtDate(p.data.date)} · {p.data.author}</div>
              <h2 class="post-title">{p.data.title}</h2>
              {p.data.description && <p class="post-desc">{p.data.description}</p>}
              <div class="post-tags">
                {p.data.tags.map(tag => <span class="post-tag">#{tag}</span>)}
              </div>
            </div>
          </a>
        );
      })}
    </div>
    <div id="empty-state" class="empty-state" hidden>
      <p>{t('blog.empty_state')}</p>
    </div>
  </div>
</main>

<AITranslatedBadge lang={lang} show={showAIBadge} />

<style>
  .blog-page { background: var(--theme-bg); min-height: 100vh; padding: 140px 32px 100px; }
  .container { max-width: 1100px; margin: 0 auto; }

  .blog-header { margin-bottom: 32px; }
  .section-num { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--theme-accent); letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 10px; }
  .blog-h1 { font-family: 'Space Grotesk', sans-serif; font-weight: 800; font-size: clamp(40px, 6vw, 64px); color: var(--theme-text); line-height: 1.05; margin: 0 0 12px; letter-spacing: -0.02em; }
  .blog-sub { font-family: 'DM Sans', sans-serif; font-size: 16px; color: var(--theme-text-muted); margin: 0; }

  .search-wrap { display: flex; flex-direction: column; gap: 14px; margin-bottom: 36px; }
  #blog-search {
    width: 100%; padding: 14px 18px; border-radius: 12px;
    background: var(--theme-surface); border: 1px solid var(--theme-border);
    color: var(--theme-text); font-family: 'Space Mono', monospace; font-size: 14px;
    outline: none; transition: border-color 0.2s, box-shadow 0.2s;
  }
  #blog-search:focus { border-color: var(--theme-accent); box-shadow: var(--theme-glow); }
  #blog-search::placeholder { color: var(--theme-text-muted); }

  .tag-filters { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag-pill {
    appearance: none; border: 1px solid var(--theme-border); background: transparent;
    color: var(--theme-text-muted); font-family: 'Space Mono', monospace;
    font-size: 11px; padding: 6px 12px; border-radius: 999px; cursor: pointer;
    transition: all 0.2s; letter-spacing: 0.04em;
  }
  .tag-pill:hover { color: var(--theme-accent); }
  .tag-pill.active { background: color-mix(in srgb, var(--theme-accent) 15%, transparent); color: var(--theme-accent); border-color: var(--theme-accent); }

  .post-list { display: grid; grid-template-columns: 1fr; gap: 18px; }
  .post-card {
    display: grid; grid-template-columns: 220px 1fr; gap: 24px;
    padding: 22px; background: var(--theme-surface); border: 1px solid var(--theme-border);
    border-radius: 16px; text-decoration: none; color: inherit;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
  }
  .post-card:hover { transform: translateY(-4px); background: var(--theme-surface-hover); border-color: color-mix(in srgb, var(--theme-accent) 50%, transparent); box-shadow: var(--theme-glow); }
  .post-img-wrap { width: 100%; height: 140px; border-radius: 10px; overflow: hidden; background: var(--theme-bg); }
  .post-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .post-body { display: flex; flex-direction: column; gap: 8px; }
  .post-meta { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--theme-accent); letter-spacing: 0.08em; }
  .post-title { font-family: 'Space Grotesk', sans-serif; font-weight: 800; font-size: 22px; color: var(--theme-text); margin: 0; line-height: 1.25; }
  .post-desc { font-family: 'DM Sans', sans-serif; font-size: 14px; color: var(--theme-text-muted); margin: 0; line-height: 1.65; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
  .post-tag { font-family: 'Space Mono', monospace; font-size: 10px; padding: 2px 9px; border-radius: 999px; background: color-mix(in srgb, var(--theme-accent) 12%, transparent); color: var(--theme-accent); }

  .empty-state { padding: 40px; text-align: center; color: var(--theme-text-muted); font-family: 'Space Mono', monospace; }

  @media (max-width: 720px) {
    .blog-page { padding: 110px 18px 70px; }
    .post-card { grid-template-columns: 1fr; }
    .post-img-wrap { height: 180px; }
  }
</style>

<script>
  function bindBlogList() {
    const search = document.getElementById('blog-search') as HTMLInputElement | null;
    const list = document.getElementById('post-list');
    const empty = document.getElementById('empty-state');
    const tagBtns = document.querySelectorAll<HTMLButtonElement>('.tag-pill');
    if (!list) return;
    let activeTag = '__all__';

    function applyFilter() {
      if (!list) return;
      const q = (search?.value || '').toLowerCase().trim();
      const cards = Array.from(list.querySelectorAll<HTMLAnchorElement>('.post-card'));
      let visible = 0;
      cards.forEach(c => {
        const title = c.dataset.title || '';
        const desc = c.dataset.desc || '';
        const tags = (c.dataset.tags || '').split(',');
        const matchQ = !q || title.includes(q) || desc.includes(q) || tags.some(t => t.includes(q));
        const matchTag = activeTag === '__all__' || tags.includes(activeTag.toLowerCase());
        const show = matchQ && matchTag;
        c.style.display = show ? 'grid' : 'none';
        if (show) visible++;
      });
      if (empty) (empty as HTMLElement).hidden = visible !== 0;
    }

    search?.addEventListener('input', applyFilter);
    tagBtns.forEach(b => b.addEventListener('click', () => {
      tagBtns.forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      activeTag = b.dataset.tag || '__all__';
      applyFilter();
    }));
  }
  bindBlogList();
  document.addEventListener('astro:page-load', bindBlogList);
</script>
