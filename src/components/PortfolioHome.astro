---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import linkedinIcon from '../assets/icon-linkedin.svg';
import githubIcon from '../assets/icon-github.svg';
import { useTranslations, localeMeta, type Locale } from '../i18n';
import Nav from './Nav.astro';
import AITranslatedBadge from './AITranslatedBadge.astro';

import enCaseStudies from '../content/case-studies/en.json';
import ptCaseStudies from '../content/case-studies/pt-br.json';

interface Props {
  lang: Locale;
  pathname: string;
}

const { lang, pathname } = Astro.props;
const t = useTranslations(lang);

const profileEntries = await getCollection('profile', (p) => p.id.startsWith(`${lang}/`) || p.id === lang);
const profileEntry = profileEntries[0];
if (!profileEntry) throw new Error(`Missing profile content for locale ${lang}`);
const profile = profileEntry.data;

const careerEntries = await getCollection('career', (p) => p.id.startsWith(`${lang}/`) || p.id === lang);
const careerEntry = careerEntries[0];
if (!careerEntry) throw new Error(`Missing career content for locale ${lang}`);
const career = careerEntry.data;
const EXPERIENCE = career.entries;
const CV_URL = career.cv_url;

const allProjects = await getCollection('projects', (p) => p.id.startsWith(`${lang}/`));
const projects = allProjects.sort((a, b) => {
  const tiers: Record<string, number> = { S: 1, A: 2, B: 3, C: 4 };
  return (tiers[a.data.tier] || 99) - (tiers[b.data.tier] || 99);
});

const allBlogPosts = await getCollection('blog', (p) => p.id.startsWith(`${lang}/`));
const blogPosts = allBlogPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmtDate = (d: Date) =>
  d.toLocaleDateString(localeMeta[lang].dateLocale, { month: 'short', year: 'numeric' });

const caseStudiesData = lang === 'en' ? enCaseStudies : ptCaseStudies;
const CASE_STUDIES = caseStudiesData.items;

const ALL_FILTERS = [t('projects.filter_all'), 'Kotlin', 'Android', 'KMP', 'Compose', 'Flutter', 'Rust'];
const FILTER_ICONS: Record<string, string> = {
  Kotlin: 'devicon-kotlin-plain',
  Android: 'devicon-android-plain',
  KMP: 'devicon-kotlin-plain',
  Compose: 'devicon-jetpackcompose-plain',
  Flutter: 'devicon-flutter-plain',
  Rust: 'devicon-rust-plain',
};
const skills = profile.stack;

const homeBase = lang === 'en' ? '/' : `/${lang}/`;
const blogPath = lang === 'en' ? '/blog/' : `/${lang}/blog/`;
const projectBase = lang === 'en' ? '/projects/' : `/${lang}/projects/`;
const blogPostBase = lang === 'en' ? '/blog/' : `/${lang}/blog/`;

const links = [
  { label: t('contact.email_label'), href: 'mailto:contact@luisamartins.dev', pre: '✉️', icon: null },
  { label: t('contact.github_label'), href: 'https://github.com/lomartins', pre: null, icon: githubIcon },
  { label: t('contact.linkedin_label'), href: 'https://www.linkedin.com/in/lomartins/', pre: null, icon: linkedinIcon },
];

function getTechColor(label: string) {
  const TECH_COLORS: Record<string, string> = {
    Kotlin: '#7F52FF', Android: '#3DDC84', KMP: '#bd93f9', Rust: '#CE422B',
    Compose: '#4285F4', Room: '#FF6D00', CLI: '#50FA7B', Material3: '#E91E63',
    Python: '#3572A5', Axum: '#CE422B', SQLite: '#0085CA', Koin: '#FF6B6B',
    MockK: '#8be9fd', Observability: '#ffb86c', Architecture: '#ff79c6',
  };
  return TECH_COLORS[label] || 'var(--theme-accent)';
}

const showAIBadge =
  profile.ai_translated || career.ai_translated || caseStudiesData.ai_translated;

const stripLocale = (id: string) => id.replace(new RegExp(`^${lang}/`), '');
---

<Nav lang={lang} pathname={pathname} homeBase={homeBase} blogPath={blogPath} />

<section class="hero-section" data-screen-label="01 Hero">
  <div class="hero-grid-bg"></div>
  <div class="hero-sun-container">
    <div class="hero-sun"></div>
    <div class="hero-sun-line" style="height: 5%; bottom: 0;"></div>
    <div class="hero-sun-line" style="height: 6.5%; bottom: 12.5%;"></div>
    <div class="hero-sun-line" style="height: 8%; bottom: 25%;"></div>
    <div class="hero-sun-line" style="height: 9.5%; bottom: 37.5%;"></div>
    <div class="hero-sun-line" style="height: 11%; bottom: 50%;"></div>
    <div class="hero-sun-line" style="height: 12.5%; bottom: 62.5%;"></div>
    <div class="hero-sun-line" style="height: 14%; bottom: 75%;"></div>
  </div>
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <div>
      {profile.avatar && (
        <img src={profile.avatar} alt={profile.name} loading="eager" decoding="async" class="hero-avatar" />
      )}
      <div class="hero-subtitle">{'>'} {profile.hero_title}</div>
      <h1 class="glitch-wrap hero-title" data-text={profile.name}>{profile.name}</h1>
      <p class="hero-desc">{profile.hero_description}</p>
      <div class="hero-badges">
        {profile.hero_tags.map(t => {
          const bg = getTechColor(t);
          return <span class="tech-badge" style={`--badge-color: ${bg};`}>{t}</span>
        })}
      </div>
      <div class="hero-actions">
        <a href={`${homeBase}#projects`} class="btn-primary">{t('hero.view_projects')}</a>
        <a href={`${homeBase}#contact`} class="btn-secondary">{t('hero.say_hello')}</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="terminal-container">
        <div class="terminal-window">
          <div class="term-line"><span class="term-prompt">$</span> whoami</div>
          <div class="term-line"><span class="term-green">{profile.name.toLowerCase().replace(' ', '_')}</span></div>
          <div class="term-line"><span class="term-prompt">$</span> stack --list</div>
          <div class="term-line"><span class="term-cyan">{profile.hero_tags.map(t => t.toLowerCase()).join(' ')}</span></div>
          <div class="term-line"><span class="term-prompt">$</span> status</div>
          <div class="term-line"><span class="term-accent-alt">{profile.about_status} 🟢</span></div>
        </div>
      </div>

      <div class="hero-bg-text">モバイル<br />開発者</div>
    </div>
  </div>

  <div class="scroll-indicator">
    <span>{t('hero.scroll')}</span>
    <div class="scroll-line"></div>
  </div>
</section>

<section id="about" class="section-surface">
  <div class="container">
    <div class="section-header">
      <div class="section-num">01 / {t('section.about')}</div>
      <h2 class="section-title">{profile.about_title_1}<br /><span class="text-accent">{profile.about_title_2}</span></h2>
    </div>
    <div class="about-grid">
      <div>
        <p class="about-desc">{profile.about_paragraph_1}</p>
        <p class="about-desc">{profile.about_paragraph_2}</p>
        <div class="about-status">
          <span class="text-accent">$</span> {profile.about_status}
        </div>
      </div>
      <div>
        <div class="stack-title">{t('about.stack')}</div>
        <div class="badges-wrap">
          {skills.map(s => {
            const bg = getTechColor(s);
            return <span class="tech-badge" style={`--badge-color: ${bg};`}>{s}</span>
          })}
        </div>
      </div>
    </div>
  </div>
</section>

<section id="projects" class="section-bg">
  <div class="container">
    <div class="section-header">
      <div class="section-num">02 / {t('section.projects')}</div>
      <h2 class="section-title">{t('projects.heading')}</h2>
    </div>

    <div class="filter-wrap" id="project-filters">
      {ALL_FILTERS.map((label, idx) => (
        <button class={`filter-btn ${idx === 0 ? 'active' : ''}`} data-filter={idx === 0 ? '__all__' : label}>
          {FILTER_ICONS[label] && <i class={`${FILTER_ICONS[label]} filter-icon`}></i>}{label}
        </button>
      ))}
    </div>

    <div class="projects-grid" id="projects-grid">
      {projects.map(p => {
        const slug = stripLocale(p.id);
        return (
          <a href={`${projectBase}${slug}`} class="project-card" data-tech={p.data.tech.join(',')}>
            <div class="project-card-highlight"></div>
            <div class="project-emoji">
              {p.data.image
                ? <Image src={p.data.image} alt="" inferSize={true} loading="lazy" decoding="async" />
                : p.data.emoji}
            </div>
            <h3 class="project-name">{p.data.name}</h3>
            <p class="project-desc">{p.data.description}</p>
            <div class="badges-wrap">
              {p.data.tech.map((tag) => {
                const bg = getTechColor(tag);
                return <span class="tech-badge" style={`--badge-color: ${bg};`}>{tag}</span>
              })}
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<section id="case-studies" class="section-surface">
  <div class="container">
    <div class="case-study-header-wrap">
      <div class="portal-ring">
        <div class="portal-inner"></div>
      </div>
      <div class="section-header" style="margin-bottom: 0;">
        <div class="section-num">03 / {t('section.case_studies')}</div>
        <h2 class="section-title">{t('case_studies.heading_line_1')}<br /><span class="text-accent">{t('case_studies.heading_line_2')}</span></h2>
      </div>
    </div>

    <div class="case-studies-wrap">
      {CASE_STUDIES.map((cs) => (
        <div class="case-study-card">
          <details>
            <summary>
              <div class="cs-summary-content">
                <div class="cs-category">{cs.category}</div>
                <h3 class="cs-title">{cs.title}</h3>
                <p class="cs-desc">{cs.summary}</p>
              </div>
              <div class="cs-arrow">↓</div>
            </summary>
            <div class="cs-details">
              {cs.sections.map((sec, i) => (
                <div class="cs-section" style={i < cs.sections.length - 1 ? "margin-bottom: 20px;" : ""}>
                  <h4 class="cs-sec-title">{sec.title}</h4>
                  <p class="cs-sec-content">{sec.content}</p>
                </div>
              ))}
              <div class="badges-wrap" style="margin-top: 20px;">
                {cs.tech.map((tag) => {
                  const bg = getTechColor(tag);
                  return <span class="tech-badge" style={`--badge-color: ${bg};`}>{tag}</span>
                })}
              </div>
            </div>
          </details>
        </div>
      ))}
    </div>
  </div>
</section>

<section id="blog" class="section-bg">
  <div class="container">
    <div class="section-header">
      <div class="section-num">04 / {t('section.writing')}</div>
      <h2 class="section-title">{t('blog.heading')}</h2>
    </div>
    <div class="blog-grid">
      {blogPosts.map(post => {
        const slug = stripLocale(post.id);
        return (
          <a href={`${blogPostBase}${slug}/`} class="blog-card">
            {post.data.img && <img src={post.data.img} alt="" loading="lazy" decoding="async" class="blog-card-img" onerror="if(!this.dataset.f){this.dataset.f='1';this.src='/blog/fallback.svg';}" />}
            <div class="blog-meta">{fmtDate(post.data.date)} · {post.data.author}</div>
            <h3 class="blog-title">{post.data.title}</h3>
            {post.data.description && <p class="blog-excerpt">{post.data.description}</p>}
            <div class="badges-wrap">
              {post.data.tags.map((tag) => (
                <span class="blog-tag">#{tag}</span>
              ))}
            </div>
          </a>
        );
      })}
    </div>
    <div style="margin-top: 28px; text-align: center;">
      <a href={blogPath} class="btn-secondary">{t('blog.read_all')}</a>
    </div>
  </div>
</section>

<section id="resume" class="section-surface">
  <div class="container">
    <div class="resume-header-wrap">
      <div class="section-header" style="margin-bottom: 0;">
        <div class="section-num">05 / {t('section.experience')}</div>
        <h2 class="section-title">{t('resume.heading')}</h2>
      </div>
      <a href={CV_URL} class="btn-download" {...CV_URL !== '#' ? { download: true, target: '_blank', rel: 'noopener noreferrer' } : {}}>{t('resume.download_cv')}</a>
    </div>

    <div class="timeline-wrap">
      {EXPERIENCE.map((item, i) => (
        <div class="timeline-item">
          <div class="timeline-marker-wrap">
            <div class="timeline-marker"></div>
            {i < EXPERIENCE.length - 1 && <div class="timeline-line"></div>}
          </div>
          <div class="timeline-content" style={i < EXPERIENCE.length - 1 ? "padding-bottom: 36px;" : ""}>
            <div class="timeline-period">{item.period}</div>
            <div class="timeline-role">{item.role}</div>
            <div class="timeline-company">
              {item.logo && <img src={item.logo} alt={item.company} loading="lazy" decoding="async" class="company-logo" />}
              {item.url ? <a href={item.url} class="company-link" target="_blank" rel="noopener noreferrer">{item.company}</a> : item.company}
            </div>
            <p class="timeline-desc">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section id="contact" class="section-bg">
  <div class="container" style="text-align: center;">
    <div class="section-header">
      <div class="section-num">06 / {t('section.contact')}</div>
      <h2 class="section-title">{t('contact.heading_line_1')}<br /><span class="text-accent">{t('contact.heading_line_2')}</span></h2>
    </div>
    <p class="contact-desc">{t('contact.description')}</p>
    <div class="contact-links">
      {links.map(l => (
        <a href={l.href} class="contact-link">
          {l.icon ? <l.icon/> : l.pre}
          {l.label}
        </a>
      ))}
    </div>
  </div>
</section>

<footer class="footer">
  <div class="footer-content">
    <div class="footer-left">
      <div class="footer-blaahaj">
        <svg viewBox="0 0 200 120" width="44" height="26.4" style="animation: float 4s ease-in-out infinite;">
          <ellipse cx="100" cy="65" rx="85" ry="38" fill="#5bbbd4" />
          <ellipse cx="106" cy="76" rx="58" ry="20" fill="#d8eff6" />
          <polygon points="118,25 148,62 90,62" fill="#3d9dbc" />
          <polygon points="82,76 52,102 88,82" fill="#3d9dbc" />
          <polygon points="18,48 2,25 32,60" fill="#3d9dbc" />
          <polygon points="18,75 2,95 32,60" fill="#3d9dbc" />
          <circle cx="158" cy="58" r="7" fill="#1a1a2e" />
          <circle cx="160" cy="55.5" r="2.5" fill="white" />
          <path d="M 146 70 Q 157 79 168 70" fill="none" stroke="#1a1a2e" stroke-width="2.5" stroke-linecap="round" />
          <path d="M 138 60 Q 141 68 138 76" fill="none" stroke="rgba(61,157,188,0.7)" stroke-width="1.5" />
          <ellipse cx="177" cy="64" rx="10" ry="7" fill="#6dcee5" opacity="0.6" />
        </svg>
      </div>
      <span class="footer-text">{t('footer.made_with')}</span>
    </div>
    <span class="footer-text">{t('footer.copyright')}</span>
  </div>
</footer>

<AITranslatedBadge lang={lang} show={showAIBadge} />

<style>
  .hero-section { min-height: 100vh; position: relative; display: flex; align-items: center; overflow: hidden; background: var(--theme-bg); }
  .hero-grid-bg { position: absolute; bottom: 0; left: 0; right: 0; height: 46%; background-image: linear-gradient(var(--theme-grid-color) 1px, transparent 1px), linear-gradient(90deg, var(--theme-grid-color) 1px, transparent 1px); background-size: 60px 60px; transform: perspective(420px) rotateX(62deg); transform-origin: bottom; -webkit-mask-image: linear-gradient(to top, black 0%, transparent 100%); mask-image: linear-gradient(to top, black 0%, transparent 100%); }
  .hero-sun-container { position: absolute; bottom: 37%; left: 50%; transform: translateX(-50%); width: 320px; height: 160px; overflow: hidden; animation: sunrisePulse 3s ease-in-out infinite; }
  .hero-sun { position: absolute; inset: 0; border-radius: 320px 320px 0 0; background: linear-gradient(to bottom, var(--theme-sun-0), var(--theme-sun-1) 50%, var(--theme-sun-2)); }
  .hero-sun-line { position: absolute; left: 0; right: 0; background: var(--theme-bg); }
  .hero-overlay { position: absolute; inset: 0; pointer-events: none; z-index: 1; background-image: repeating-linear-gradient(0deg,rgba(0,0,0,0.04) 0px,rgba(0,0,0,0.04) 1px,transparent 1px,transparent 4px); }
  .hero-content { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 0 32px; width: 100%; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; padding-top: 80px; animation: fadeUp 1s ease forwards; }
  .hero-avatar { width: 88px; height: 88px; border-radius: 50%; object-fit: cover; display: block; margin-bottom: 20px; border: 2px solid var(--theme-accent); box-shadow: var(--theme-glow); background: var(--theme-surface); }
  .hero-subtitle { font-family: 'Space Mono', monospace; font-size: 12px; color: var(--theme-accent-alt); letter-spacing: 0.22em; text-transform: uppercase; margin-bottom: 16px; }
  .hero-title { font-family: 'Space Grotesk', sans-serif; font-weight: 800; font-size: clamp(44px, 7.5vw, 100px); line-height: 0.95; color: var(--theme-text); margin-bottom: 24px; letter-spacing: -0.03em; text-shadow: 0 0 60px color-mix(in srgb, var(--theme-accent) 30%, transparent); }
  .hero-desc { font-family: 'DM Sans', sans-serif; font-size: 16px; color: var(--theme-text-muted); line-height: 1.8; max-width: 460px; margin-bottom: 28px; }
  .hero-badges { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 32px; }
  .hero-actions { display: flex; gap: 12px; }
  .btn-primary { padding: 13px 28px; border-radius: 12px; background: var(--theme-accent); color: var(--theme-bg); font-family: 'Space Mono', monospace; font-weight: 700; font-size: 12px; text-decoration: none; letter-spacing: 0.06em; transition: all 0.2s; box-shadow: var(--theme-glow); }
  .btn-primary:hover { transform: translateY(-2px); }
  .btn-secondary { padding: 13px 28px; border-radius: 12px; border: 1px solid var(--theme-border); color: var(--theme-text); font-family: 'Space Mono', monospace; font-weight: 700; font-size: 12px; text-decoration: none; letter-spacing: 0.06em; transition: all 0.2s; background: color-mix(in srgb, var(--theme-surface) 80%, transparent); backdrop-filter: blur(6px); }
  .btn-secondary:hover { border-color: var(--theme-accent); color: var(--theme-accent); background: color-mix(in srgb, var(--theme-surface) 92%, transparent); }

  .hero-right { display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; gap: 10px; }
  .hero-bg-text { position: absolute; top: 0; right: -8px; font-family: 'Space Mono', monospace; font-size: 44px; color: color-mix(in srgb, var(--theme-accent) 12%, transparent); line-height: 1.25; user-select: none; font-weight: 700; pointer-events: none; }

  .terminal-container { display: block; }
  .terminal-window { background: var(--theme-surface); border: 1px solid var(--theme-border); border-radius: 16px; padding: 2em 8em 4em 2em; width: 100%; max-width: 400px; font-family: 'Space Mono', monospace; font-size: 13px; line-height: 2; color: var(--theme-text-muted); }
  .term-prompt { color: var(--theme-accent); }
  .term-green { color: var(--theme-green); }
  .term-cyan { color: var(--theme-cyan); }
  .term-accent-alt { color: var(--theme-accent-alt); }

  .scroll-indicator { position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%); z-index: 2; font-family: 'Space Mono', monospace; font-size: 10px; color: var(--theme-text-muted); letter-spacing: 0.2em; display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .scroll-line { width: 1px; height: 32px; background: linear-gradient(to bottom, var(--theme-accent), transparent); animation: float 2s ease-in-out infinite; }

  .section-surface { background: var(--theme-surface); padding: 100px 32px; }
  .section-bg { background: var(--theme-bg); padding: 100px 32px; }
  .container { max-width: 1200px; margin: 0 auto; }

  .section-header { margin-bottom: 40px; }
  .section-num { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--theme-accent); letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 12px; }
  .section-title { font-family: 'Space Grotesk', sans-serif; font-weight: 800; font-size: clamp(36px, 5vw, 60px); color: var(--theme-text); line-height: 1.1; margin: 0; }
  .text-accent { color: var(--theme-accent); }

  .about-grid { display: grid; grid-template-columns: 3fr 2fr; gap: 64px; align-items: start; }
  .about-desc { font-family: 'DM Sans', sans-serif; font-size: 16px; color: var(--theme-text-muted); line-height: 1.85; margin: 0 0 20px; }
  .about-status { font-family: 'Space Mono', monospace; font-size: 13px; color: var(--theme-accent-alt); padding: 14px 20px; background: color-mix(in srgb, var(--theme-accent-alt) 10%, transparent); border: 1px solid color-mix(in srgb, var(--theme-accent-alt) 30%, transparent); border-radius: 10px; display: inline-block; margin-top: 8px; }
  .stack-title { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--theme-text-muted); letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 16px; }

  .badges-wrap { display: flex; flex-wrap: wrap; gap: 8px; }
  .tech-badge { display: inline-flex; align-items: center; padding: 5px 12px; border-radius: 20px; font-size: 12px; font-family: 'Space Mono', monospace; font-weight: 700; background: color-mix(in srgb, var(--badge-color) 22%, var(--theme-bg)); color: color-mix(in srgb, var(--badge-color) 70%, white); border: 1px solid color-mix(in srgb, var(--badge-color) 55%, transparent); letter-spacing: 0.05em; white-space: nowrap; text-shadow: 0 1px 2px rgba(0,0,0,0.4); }

  .filter-wrap { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 40px; }
  .filter-btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 18px; border-radius: 20px; cursor: pointer; border: 1px solid var(--theme-border); background: transparent; color: var(--theme-text-muted); font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.06em; transition: all 0.2s; }
  .filter-icon { font-size: 14px; line-height: 1; }
  .filter-btn.active { border-color: var(--theme-accent); background: color-mix(in srgb, var(--theme-accent) 14%, transparent); color: var(--theme-accent); }

  .projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 20px; }
  .project-card { text-decoration: none; display: block; background: var(--theme-surface); border: 1px solid var(--theme-border); border-radius: 16px; padding: 24px; cursor: pointer; transition: all 0.3s ease; position: relative; overflow: hidden; }
  .project-card:hover { background: var(--theme-surface-hover); border-color: color-mix(in srgb, var(--theme-accent) 70%, transparent); box-shadow: var(--theme-glow); transform: translateY(-4px); }
