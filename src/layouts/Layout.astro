---
interface Props {
	title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="vaporwave">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600;700;800&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500&display=swap');

	:root[data-theme="vaporwave"] {
		--theme-name: '// vaporwave';
		--theme-bg: #0d0e14;
		--theme-surface: #1a1b26;
		--theme-surface-hover: #22233a;
		--theme-accent: #bd93f9;
		--theme-accent-alt: #ff79c6;
		--theme-cyan: #8be9fd;
		--theme-green: #50fa7b;
		--theme-text: #f8f8f2;
		--theme-text-muted: #6272a4;
		--theme-border: rgba(189,147,249,0.18);
		--theme-glow: 0 0 28px rgba(189,147,249,0.4);
		--theme-grid-color: rgba(189,147,249,0.13);
		--theme-sun-0: #ff79c6;
		--theme-sun-1: #bd93f9;
		--theme-sun-2: #8be9fd;
	}

	:root[data-theme="terminal"] {
		--theme-name: '// terminal';
		--theme-bg: #0a0e0a;
		--theme-surface: #0f180f;
		--theme-surface-hover: #162016;
		--theme-accent: #50fa7b;
		--theme-accent-alt: #8be9fd;
		--theme-cyan: #8be9fd;
		--theme-green: #50fa7b;
		--theme-text: #f8f8f2;
		--theme-text-muted: #456040;
		--theme-border: rgba(80,250,123,0.15);
		--theme-glow: 0 0 28px rgba(80,250,123,0.35);
		--theme-grid-color: rgba(80,250,123,0.09);
		--theme-sun-0: #50fa7b;
		--theme-sun-1: #ffb86c;
		--theme-sun-2: #8be9fd;
	}

	:root[data-theme="portal"] {
		--theme-name: '// aperture';
		--theme-bg: #080810;
		--theme-surface: #0f0f1e;
		--theme-surface-hover: #16162a;
		--theme-accent: #ff6633;
		--theme-accent-alt: #55aaff;
		--theme-cyan: #55aaff;
		--theme-green: #50fa7b;
		--theme-text: #f8f8f2;
		--theme-text-muted: #50508a;
		--theme-border: rgba(255,102,51,0.2);
		--theme-glow: 0 0 28px rgba(255,102,51,0.4);
		--theme-grid-color: rgba(85,170,255,0.09);
		--theme-sun-0: #ff6633;
		--theme-sun-1: #ff9900;
		--theme-sun-2: #55aaff;
	}

	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
	html { scroll-behavior: smooth; }
	body { 
		overflow-x: hidden; 
		background: var(--theme-bg);
		color: var(--theme-text);
		transition: background 0.3s ease, color 0.3s ease;
	}

	@keyframes float {
		0%, 100% { transform: translateY(0px) rotate(-2deg); }
		50% { transform: translateY(-18px) rotate(2deg); }
	}
	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(28px); }
		to   { opacity: 1; transform: translateY(0); }
	}
	@keyframes glitchFlash {
		0%   { clip-path: inset(0 0 90% 0); transform: translate(-3px, 0); }
		20%  { clip-path: inset(30% 0 50% 0); transform: translate(3px, 0); }
		40%  { clip-path: inset(60% 0 20% 0); transform: translate(-2px, 0); }
		60%  { clip-path: inset(10% 0 70% 0); transform: translate(2px, 0); }
		80%  { clip-path: inset(80% 0 5% 0); transform: translate(-3px, 0); }
		100% { clip-path: inset(0 0 0 0); transform: translate(0, 0); }
	}
	@keyframes sunrisePulse {
		0%, 100% { opacity: 0.85; }
		50%       { opacity: 1; }
	}
	@keyframes scanScroll {
		from { background-position: 0 0; }
		to   { background-position: 0 100vh; }
	}

	.glitch-wrap { position: relative; display: inline-block; cursor: default; }
	.glitch-wrap::before,
	.glitch-wrap::after {
		content: attr(data-text);
		position: absolute; top: 0; left: 0;
		font-family: inherit; font-weight: inherit; font-size: inherit;
		line-height: inherit; color: inherit; width: 100%;
		opacity: 0; pointer-events: none;
	}
	.glitch-wrap:hover::before {
		color: var(--theme-accent-alt);
		animation: glitchFlash 0.4s steps(1) infinite;
		opacity: 0.8;
	}
	.glitch-wrap:hover::after {
		color: var(--theme-cyan);
		animation: glitchFlash 0.4s steps(1) infinite reverse;
		opacity: 0.6;
	}

	::-webkit-scrollbar { width: 5px; }
	::-webkit-scrollbar-track { background: var(--theme-bg); }
	::-webkit-scrollbar-thumb { background: var(--theme-accent); border-radius: 3px; }
</style>
