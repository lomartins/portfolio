---
import { ClientRouter } from 'astro:transitions';
import { localeMeta, defaultLocale, type Locale } from '../i18n';

interface Props {
	title: string;
	lang?: Locale;
}
const { title, lang = defaultLocale } = Astro.props;
const htmlLang = localeMeta[lang].htmlLang;
---

<!doctype html>
<html lang={htmlLang} data-theme="vaporwave">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" href="/favicon.ico" sizes="any">
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
		<ClientRouter />
	</head>
	<body>
		<div id="theme-shockwave" aria-hidden="true"></div>
		<slot />
	</body>
</html>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600;700;800&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500&display=swap');

	:root[data-theme="vaporwave"] {
		--theme-name: '// vaporwave';
		--theme-bg: #0d0e14;
		--theme-surface: #1a1b26;
		--theme-surface-hover: #22233a;
		--theme-accent: #bd93f9;
		--theme-accent-alt: #ff79c6;
		--theme-cyan: #8be9fd;
		--theme-green: #50fa7b;
		--theme-text: #f8f8f2;
		--theme-text-muted: #6272a4;
		--theme-border: rgba(189,147,249,0.18);
		--theme-glow: 0 0 28px rgba(189,147,249,0.4);
		--theme-grid-color: rgba(189,147,249,0.13);
		--theme-sun-0: #ff79c6;
		--theme-sun-1: #bd93f9;
		--theme-sun-2: #8be9fd;
	}

	:root[data-theme="terminal"] {
		--theme-name: '// terminal';
		--theme-bg: #0a0e0a;
		--theme-surface: #0f180f;
		--theme-surface-hover: #162016;
		--theme-accent: #50fa7b;
		--theme-accent-alt: #8be9fd;
		--theme-cyan: #8be9fd;
		--theme-green: #50fa7b;
		--theme-text: #f8f8f2;
		--theme-text-muted: #456040;
		--theme-border: rgba(80,250,123,0.15);
		--theme-glow: 0 0 28px rgba(80,250,123,0.35);
		--theme-grid-color: rgba(80,250,123,0.09);
		--theme-sun-0: #50fa7b;
		--theme-sun-1: #ffb86c;
		--theme-sun-2: #8be9fd;
	}

	:root[data-theme="light"] {
		--theme-name: '// daylight';
		--theme-bg: #f4f4f7;
		--theme-surface: #ffffff;
		--theme-surface-hover: #ececf2;
		--theme-accent: #6d28d9;
		--theme-accent-alt: #db2777;
		--theme-cyan: #0891b2;
		--theme-green: #059669;
		--theme-text: #14141c;
		--theme-text-muted: #6b6b80;
		--theme-border: rgba(109,40,217,0.22);
		--theme-glow: 0 0 28px rgba(109,40,217,0.18);
		--theme-grid-color: rgba(109,40,217,0.08);
		--theme-sun-0: #db2777;
		--theme-sun-1: #6d28d9;
		--theme-sun-2: #0891b2;
	}

	:root[data-theme="portal"] {
		--theme-name: '// aperture';
		--theme-bg: #080810;
		--theme-surface: #0f0f1e;
		--theme-surface-hover: #16162a;
		--theme-accent: #ff6633;
		--theme-accent-alt: #55aaff;
		--theme-cyan: #55aaff;
		--theme-green: #50fa7b;
		--theme-text: #f8f8f2;
		--theme-text-muted: #50508a;
		--theme-border: rgba(255,102,51,0.2);
		--theme-glow: 0 0 28px rgba(255,102,51,0.4);
		--theme-grid-color: rgba(85,170,255,0.09);
		--theme-sun-0: #ff6633;
		--theme-sun-1: #ff9900;
		--theme-sun-2: #55aaff;
	}

	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
	html { scroll-behavior: smooth; }
	body {
		overflow-x: hidden;
		background: var(--theme-bg);
		color: var(--theme-text);
		transition: background 0.45s ease, color 0.45s ease;
	}

	@keyframes float {
		0%, 100% { transform: translateY(0px) rotate(-2deg); }
		50% { transform: translateY(-18px) rotate(2deg); }
	}
	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(28px); }
		to   { opacity: 1; transform: translateY(0); }
	}
	@keyframes glitchFlash {
		0%   { clip-path: inset(0 0 90% 0); transform: translate(-3px, 0); }
		20%  { clip-path: inset(30% 0 50% 0); transform: translate(3px, 0); }
		40%  { clip-path: inset(60% 0 20% 0); transform: translate(-2px, 0); }
		60%  { clip-path: inset(10% 0 70% 0); transform: translate(2px, 0); }
		80%  { clip-path: inset(80% 0 5% 0); transform: translate(-3px, 0); }
		100% { clip-path: inset(0 0 0 0); transform: translate(0, 0); }
	}
	@keyframes sunrisePulse {
		0%, 100% { opacity: 0.85; }
		50%       { opacity: 1; }
	}
	@keyframes scanScroll {
		from { background-position: 0 0; }
		to   { background-position: 0 100vh; }
	}

	.glitch-wrap { position: relative; display: inline-block; cursor: default; }
	.glitch-wrap::before,
	.glitch-wrap::after {
		content: attr(data-text);
		position: absolute; top: 0; left: 0;
		font-family: inherit; font-weight: inherit; font-size: inherit;
		line-height: inherit; color: inherit; width: 100%;
		opacity: 0; pointer-events: none;
	}
	.glitch-wrap:hover::before {
		color: var(--theme-accent-alt);
		animation: glitchFlash 0.4s steps(1) infinite;
		opacity: 0.8;
	}
	.glitch-wrap:hover::after {
		color: var(--theme-cyan);
		animation: glitchFlash 0.4s steps(1) infinite reverse;
		opacity: 0.6;
	}

	::-webkit-scrollbar { width: 5px; }
	::-webkit-scrollbar-track { background: var(--theme-bg); }
	::-webkit-scrollbar-thumb { background: var(--theme-accent); border-radius: 3px; }

	/* === Theme Picker === */
	.theme-picker {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 4px;
		border-radius: 999px;
		border: 1px solid var(--theme-border);
		background: color-mix(in srgb, var(--theme-bg) 60%, transparent);
		backdrop-filter: blur(10px);
		position: relative;
	}
	.theme-picker button {
		appearance: none;
		border: 0;
		background: transparent;
		width: 26px;
		height: 26px;
		border-radius: 50%;
		cursor: pointer;
		padding: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		position: relative;
		transition: transform 0.2s ease;
	}
	.theme-picker button:hover { transform: scale(1.15) rotate(8deg); }
	.theme-picker button .swatch {
		display: block;
		width: 18px;
		height: 18px;
		border-radius: 50%;
		box-shadow: 0 0 0 1px rgba(255,255,255,0.08);
	}
	.theme-picker button[data-active="true"] .swatch {
		box-shadow: 0 0 0 2px var(--theme-text), 0 0 12px currentColor;
		animation: themePulse 1.6s ease-in-out infinite;
	}
	@keyframes themePulse {
		0%,100% { box-shadow: 0 0 0 2px var(--theme-text), 0 0 12px currentColor; }
		50%     { box-shadow: 0 0 0 2px var(--theme-text), 0 0 22px currentColor; }
	}

	/* swatch colors */
	.theme-picker button[data-theme="vaporwave"] .swatch { background: linear-gradient(135deg,#ff79c6,#bd93f9,#8be9fd); color:#bd93f9; }
	.theme-picker button[data-theme="terminal"]  .swatch { background: linear-gradient(135deg,#50fa7b,#8be9fd); color:#50fa7b; }
	.theme-picker button[data-theme="portal"]    .swatch { background: linear-gradient(135deg,#ff6633,#ff9900,#55aaff); color:#ff6633; }
	.theme-picker button[data-theme="light"]     .swatch { background: linear-gradient(135deg,#ffffff,#ececf2,#6d28d9); color:#6d28d9; box-shadow: 0 0 0 1px rgba(0,0,0,0.18); }

	/* === Subtle theme switch ripple === */
	#theme-shockwave {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 99999;
		opacity: 0;
		background: radial-gradient(circle at var(--sw-x, 50%) var(--sw-y, 50%),
			color-mix(in srgb, var(--sw-color, #fff) 22%, transparent) 0%,
			transparent 22%);
	}
	#theme-shockwave.active {
		animation: shockwaveRipple 0.55s ease-out forwards;
	}
	@keyframes shockwaveRipple {
		0%   { opacity: 0; transform: scale(0.6); }
		30%  { opacity: 0.8; }
		100% { opacity: 0; transform: scale(2.2); }
	}
</style>

<script is:inline>
	(function () {
		const KEY = 'lm-theme';
		const saved = localStorage.getItem(KEY);
		if (saved) document.documentElement.setAttribute('data-theme', saved);
	})();
</script>

<script>
	const KEY = 'lm-theme';

	function bindThemePicker() {
		const root = document.documentElement;
		const sw = document.getElementById('theme-shockwave');
		const buttons = document.querySelectorAll<HTMLButtonElement>('.theme-picker button[data-theme]');
		if (!buttons.length) return;

		const current = localStorage.getItem(KEY) || root.getAttribute('data-theme') || 'vaporwave';
		root.setAttribute('data-theme', current);
		buttons.forEach(b => b.setAttribute('data-active', String(b.dataset.theme === current)));

		buttons.forEach(btn => {
			if (btn.dataset.bound === '1') return;
			btn.dataset.bound = '1';
			btn.addEventListener('click', e => {
				const theme = btn.dataset.theme!;
				const rect = btn.getBoundingClientRect();
				const x = rect.left + rect.width / 2;
				const y = rect.top + rect.height / 2;

				const colorMap: Record<string, string> = {
					vaporwave: '#bd93f9',
					terminal:  '#50fa7b',
					portal:    '#ff6633',
					light:     '#6d28d9',
				};

				if (sw) {
					sw.style.setProperty('--sw-x', x + 'px');
					sw.style.setProperty('--sw-y', y + 'px');
					sw.style.setProperty('--sw-color', colorMap[theme] || '#fff');
					sw.classList.remove('active');
					void sw.offsetWidth;
					sw.classList.add('active');
				}

				root.setAttribute('data-theme', theme);
				localStorage.setItem(KEY, theme);
				buttons.forEach(b => b.setAttribute('data-active', String(b.dataset.theme === theme)));
			});
		});
	}

	bindThemePicker();
	document.addEventListener('astro:page-load', bindThemePicker);
</script>
