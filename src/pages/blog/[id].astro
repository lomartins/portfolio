---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`Blog Post — Luisa Martins`}>
  <div style="background: var(--theme-bg); min-height: 100vh; padding: 100px 32px;">
    <div style="max-width: 800px; margin: 0 auto; background: var(--theme-surface); border: 1px solid var(--theme-border); border-radius: 16px; padding: 40px; color: var(--theme-text); font-family: 'DM Sans', sans-serif;">
      <h1 style="font-family: 'Space Grotesk', sans-serif; font-weight: 800; font-size: clamp(32px, 5vw, 48px); margin-bottom: 24px;">
        {post.data.title}
      </h1>
      <p style="font-size: 16px; line-height: 1.8; color: var(--theme-text-muted); margin-bottom: 40px;">
        Published on {post.data.date}
      </p>
      <p style="font-size: 18px; line-height: 1.8; margin-bottom: 24px;">
        <Content />
      </p>
    </div>
  </div>
</Layout>