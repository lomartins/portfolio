---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { day: '2-digit', month: 'long', year: 'numeric' });
---

<Layout title={`${post.data.title} — Luisa Martins`}>
  <nav id="navbar" class="navbar scrolled">
    <div class="nav-gradient"></div>
    <div class="nav-content">
      <a href="/" class="nav-logo">luisamartins.dev</a>
      <div class="nav-links" id="nav-links">
        <a href="/#about" class="nav-link">about</a>
        <a href="/#projects" class="nav-link">projects</a>
        <a href="/blog/" class="nav-link active">blog</a>
        <a href="/#resume" class="nav-link">resume</a>
        <a href="/#contact" class="nav-link">contact</a>
      </div>
      <div class="nav-right">
        <div class="theme-picker" aria-label="Theme picker">
          <button data-theme="vaporwave" aria-label="Vaporwave"><span class="swatch"></span></button>
          <button data-theme="terminal"  aria-label="Terminal"><span class="swatch"></span></button>
          <button data-theme="portal"    aria-label="Portal"><span class="swatch"></span></button>
        </div>
        <button id="nav-toggle" class="nav-toggle" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </nav>

  <article class="post-page">
    <div class="container">
      <a href="/blog/" class="back-link">← all posts</a>

      <header class="post-header">
        <div class="post-meta">{fmtDate(post.data.date)} · {post.data.author}</div>
        <h1 class="post-title">{post.data.title}</h1>
        {post.data.description && <p class="post-lede">{post.data.description}</p>}
        <div class="post-tags">
          {post.data.tags.map(t => <span class="post-tag">#{t}</span>)}
        </div>
      </header>

      {post.data.img && (
        <div class="post-hero">
          <img src={post.data.img} alt="" onerror="if(!this.dataset.f){this.dataset.f='1';this.src='/blog/fallback.svg';}" />
        </div>
      )}

      <div class="post-content">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: color-mix(in srgb, var(--theme-bg) 95%, transparent); backdrop-filter: blur(16px); border-bottom: 1px solid var(--theme-border); }
  .nav-gradient { height: 5px; background: linear-gradient(90deg,#55CDFC 20%,#F7A8B8 20% 40%,#FFFFFF 40% 60%,#F7A8B8 60% 80%,#55CDFC 80%); }
  .nav-content { max-width: 1200px; margin: 0 auto; padding: 0 32px; display: flex; align-items: center; height: 58px; gap: 16px; }
  .nav-logo { font-family: 'Space Mono', monospace; font-size: 15px; font-weight: 700; color: var(--theme-accent); text-decoration: none; }
  .nav-links { display: flex; gap: 28px; margin-left: auto; }
  .nav-link { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--theme-text-muted); text-decoration: none; letter-spacing: 0.1em; }
  .nav-link.active, .nav-link:hover { color: var(--theme-accent); }
  .nav-right { display: flex; align-items: center; gap: 12px; }
  .nav-toggle { display: none; background: transparent; border: 1px solid var(--theme-border); border-radius: 8px; width: 36px; height: 36px; cursor: pointer; padding: 0; flex-direction: column; align-items: center; justify-content: center; gap: 4px; }
  .nav-toggle span { display: block; width: 16px; height: 2px; background: var(--theme-accent); border-radius: 1px; transition: transform 0.25s ease, opacity 0.25s ease; }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  .post-page { background: var(--theme-bg); min-height: 100vh; padding: 130px 32px 100px; }
  .container { max-width: 760px; margin: 0 auto; }
  .back-link { font-family: 'Space Mono', monospace; font-size: 12px; color: var(--theme-accent); text-decoration: none; display: inline-block; margin-bottom: 22px; }
  .back-link:hover { text-decoration: underline; }

  .post-header { margin-bottom: 28px; }
  .post-meta { font-family: 'Space Mono', monospace; font-size: 12px; color: var(--theme-accent); letter-spacing: 0.1em; margin-bottom: 12px; }
  .post-title { font-family: 'Space Grotesk', sans-serif; font-weight: 800; font-size: clamp(34px, 5vw, 54px); color: var(--theme-text); line-height: 1.05; margin: 0 0 14px; letter-spacing: -0.02em; }
  .post-lede { font-family: 'DM Sans', sans-serif; font-size: 18px; color: var(--theme-text-muted); margin: 0 0 16px; line-height: 1.6; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .post-tag { font-family: 'Space Mono', monospace; font-size: 11px; padding: 3px 10px; border-radius: 999px; background: color-mix(in srgb, var(--theme-accent) 12%, transparent); color: var(--theme-accent); }

  .post-hero { margin: 28px 0 36px; border-radius: 16px; overflow: hidden; border: 1px solid var(--theme-border); }
  .post-hero img { width: 100%; height: auto; max-height: 420px; object-fit: cover; display: block; }

  .post-content { font-family: 'DM Sans', sans-serif; color: var(--theme-text); font-size: 18px; line-height: 1.85; }
  .post-content :global(h1) { display: none; }
  .post-content :global(h2) {
    font-family: 'Space Grotesk', sans-serif; font-size: 30px; font-weight: 800;
    margin: 56px 0 18px; color: var(--theme-text); letter-spacing: -0.01em;
    padding-bottom: 10px; border-bottom: 1px solid var(--theme-border);
    position: relative;
  }
  .post-content :global(h2)::before {
    content: ''; position: absolute; left: 0; bottom: -1px; width: 56px; height: 2px;
    background: var(--theme-accent); border-radius: 2px;
  }
  .post-content :global(h3) {
    font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 700;
    margin: 36px 0 12px; color: var(--theme-accent); letter-spacing: -0.01em;
  }
  .post-content :global(p)  { margin: 0 0 20px; color: var(--theme-text); }
  .post-content :global(strong) { color: var(--theme-text); font-weight: 700; }
  .post-content :global(em) { color: var(--theme-accent-alt); font-style: italic; }
  .post-content :global(ul), .post-content :global(ol) { margin: 0 0 22px; padding-left: 22px; color: var(--theme-text); }
  .post-content :global(li) { margin-bottom: 8px; }
  .post-content :global(li::marker) { color: var(--theme-accent); }
  .post-content :global(a)  { color: var(--theme-accent); text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px; }
  .post-content :global(a:hover) { color: var(--theme-accent-alt); }
  .post-content :global(code) {
    font-family: 'Space Mono', monospace; font-size: 0.92em;
    background: color-mix(in srgb, var(--theme-accent) 14%, var(--theme-surface));
    padding: 2px 7px; border-radius: 5px;
    border: 1px solid color-mix(in srgb, var(--theme-accent) 30%, transparent);
    color: var(--theme-accent-alt);
  }
  .post-content :global(pre) {
    background: var(--theme-surface); border: 1px solid var(--theme-border);
    padding: 18px; border-radius: 12px; overflow-x: auto; margin: 0 0 22px;
  }
  .post-content :global(pre code) { background: transparent; border: 0; padding: 0; color: var(--theme-text); }
  .post-content :global(blockquote) {
    border-left: 3px solid var(--theme-accent);
    background: color-mix(in srgb, var(--theme-accent) 8%, transparent);
    padding: 14px 18px; color: var(--theme-text); font-style: normal;
    margin: 0 0 22px; border-radius: 0 10px 10px 0;
  }
  .post-content :global(blockquote strong) { color: var(--theme-accent); }
  .post-content :global(blockquote p) { color: var(--theme-text); margin: 0; }
  .post-content :global(hr) { border: 0; height: 1px; background: var(--theme-border); margin: 36px 0; }
  .post-content :global(img) { max-width: 100%; border-radius: 10px; display: block; margin: 18px auto; }

  @media (max-width: 720px) {
    .nav-content { padding: 0 18px; }
    .nav-links {
      position: fixed; inset: 64px 12px auto 12px; flex-direction: column; gap: 4px;
      padding: 18px; background: color-mix(in srgb, var(--theme-bg) 96%, transparent);
      backdrop-filter: blur(20px); border: 1px solid var(--theme-border); border-radius: 14px;
      transform: translateY(-12px); opacity: 0; pointer-events: none;
      transition: opacity 0.25s ease, transform 0.25s ease; z-index: 99;
    }
    .nav-links.open { opacity: 1; transform: translateY(0); pointer-events: auto; }
    .nav-toggle { display: inline-flex; }
    .nav-right { margin-left: auto; }
    .post-page { padding: 100px 18px 70px; }
    .post-content { font-size: 16px; }
  }
</style>

<script>
  const navToggle = document.getElementById('nav-toggle');
  const navLinks = document.getElementById('nav-links');
  navToggle?.addEventListener('click', () => {
    const open = navLinks?.classList.toggle('open');
    navToggle.setAttribute('aria-expanded', String(!!open));
  });
</script>
