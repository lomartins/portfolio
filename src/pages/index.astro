---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import linkedinIcon from '../assets/icon-linkedin.svg';
import githubIcon from '../assets/icon-github.svg';

const profileEntries = await getCollection('profile');
const profile = profileEntries[0].data;

const projects = (await getCollection('projects')).sort((a, b) => {
  const tiers: Record<string, number> = { S: 1, A: 2, B: 3, C: 4 };
  return (tiers[a.data.tier] || 99) - (tiers[b.data.tier] || 99);
});

const blogPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
).slice(0, 3);

const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

const CASE_STUDIES = [
  { category: 'Infrastructure В· Observability',
    title: 'Rolling out crash monitoring at scale',
    summary: 'End-to-end initiative to instrument, deploy, and drive adoption of crash monitoring across a mobile app serving millions of active users.',
    tech: ['Kotlin', 'Android', 'Observability'],
    sections: [
      { title: 'Context', content: 'The app had no centralized crash visibility. Engineers were flying blind post-release, relying on user reports to catch regressions.' },
      { title: 'Approach', content: 'Designed the SDK integration strategy, wrote internal adoption docs, coordinated with platform and observability teams, and ran the rollout in phases to minimize blast radius.' },
      { title: 'Outcome', content: 'Crash monitoring live across 100% of Android surface area. Mean time to detection dropped significantly. Became the canonical reference implementation for future observability tooling.' },
    ] },
  { category: 'Architecture В· KMP',
    title: 'Kotlin Multiplatform module migration',
    summary: 'Led migration of several business-logic modules from Android-specific Kotlin to KMP, enabling code sharing with the iOS team.',
    tech: ['Kotlin', 'KMP', 'Android', 'Architecture'],
    sections: [
      { title: 'Challenge', content: 'Modules had Android-specific dependencies baked in, test coverage was spotty, and the iOS team had a parallel implementation with drift.' },
      { title: 'Execution', content: 'Prioritized modules by blast radius and coupling. Rewrote one module at a time using expect/actual, added shared unit tests, and documented each migration as a repeatable pattern.' },
      { title: 'Result', content: 'Several core modules now shared across platforms. Reduced code duplication and eliminated sync drift between Android and iOS implementations.' },
    ] },
];

const careerEntries = await getCollection('career');
const career = careerEntries[0].data;
const EXPERIENCE = career.entries;
const CV_URL = career.cv_url;

const ALL_FILTERS = ['All', 'Kotlin', 'Android', 'KMP', 'Compose', 'Flutter', 'Rust'];
const FILTER_ICONS: Record<string, string> = {
  Kotlin: 'devicon-kotlin-plain',
  Android: 'devicon-android-plain',
  KMP: 'devicon-kotlin-plain',
  Compose: 'devicon-jetpackcompose-plain',
  Flutter: 'devicon-flutter-plain',
  Rust: 'devicon-rust-plain',
};
const skills = profile.stack;

const links = [
  { label: 'email', href: 'mailto:contact@luisamartins.dev', pre: 'вњ‰пёЏ', icon: null },
  { label: 'github', href: 'https://github.com/lomartins', pre: null, icon: githubIcon },
  { label: 'linkedin', href: 'https://www.linkedin.com/in/lomartins/', pre: null, icon: linkedinIcon },
];

const navLinks = ['About', 'Projects', 'Blog', 'Resume', 'Contact'];

function getTechColor(label: string) {
  const TECH_COLORS: Record<string, string> = {
    Kotlin: '#7F52FF', Android: '#3DDC84', KMP: '#bd93f9', Rust: '#CE422B',
    Compose: '#4285F4', Room: '#FF6D00', CLI: '#50FA7B', Material3: '#E91E63',
    Python: '#3572A5', Axum: '#CE422B', SQLite: '#0085CA', Koin: '#FF6B6B',
    MockK: '#8be9fd', Observability: '#ffb86c', Architecture: '#ff79c6',
  };
  return TECH_COLORS[label] || 'var(--theme-accent)';
}
---

<Layout title={`${profile.name} вЂ” ${profile.hero_title}`}>
  <nav id="navbar" class="navbar">
    <div class="nav-gradient"></div>
    <div class="nav-content">
      <a href="/" class="nav-logo">luisamartins.dev</a>
      <div class="nav-links" id="nav-links">
        {navLinks.map(l => (
          <a href={l.toLowerCase() === 'blog' ? '/blog/' : `#${l.toLowerCase()}`} class="nav-link">{l.toLowerCase()}</a>
        ))}
      </div>
      <div class="nav-right">
        <div class="theme-picker" aria-label="Theme picker">
          <button data-theme="vaporwave" aria-label="Vaporwave"><span class="swatch"></span></button>
          <button data-theme="terminal"  aria-label="Terminal"><span class="swatch"></span></button>
          <button data-theme="portal"    aria-label="Portal"><span class="swatch"></span></button>
        </div>
        <button id="nav-toggle" class="nav-toggle" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </nav>

  <section class="hero-section" data-screen-label="01 Hero">
    <div class="hero-grid-bg"></div>
    <div class="hero-sun-container">
      <div class="hero-sun"></div>
      <div class="hero-sun-line" style="height: 5%; bottom: 0;"></div>
      <div class="hero-sun-line" style="height: 6.5%; bottom: 12.5%;"></div>
      <div class="hero-sun-line" style="height: 8%; bottom: 25%;"></div>
      <div class="hero-sun-line" style="height: 9.5%; bottom: 37.5%;"></div>
      <div class="hero-sun-line" style="height: 11%; bottom: 50%;"></div>
      <div class="hero-sun-line" style="height: 12.5%; bottom: 62.5%;"></div>
      <div class="hero-sun-line" style="height: 14%; bottom: 75%;"></div>
    </div>
    <div class="hero-overlay"></div>

    <div class="hero-content">
      <div>
        <div class="hero-subtitle">{'>'} {profile.hero_title}</div>
        <h1 class="glitch-wrap hero-title" data-text={profile.name}>{profile.name}</h1>
        <p class="hero-desc">{profile.hero_description}</p>
        <div class="hero-badges">
          {profile.hero_tags.map(t => {
            const bg = getTechColor(t);
            return <span class="tech-badge" style={`--badge-color: ${bg};`}>{t}</span>
          })}
        </div>
        <div class="hero-actions">
          <a href="#projects" class="btn-primary">View Projects в†’</a>
          <a href="#contact" class="btn-secondary">Say hello</a>
        </div>
      </div>
      
      <div class="hero-right">
        <!-- Render Blaahaj or Terminal based on attributes using CSS -->
        <div class="blaahaj-container">
          <svg viewBox="0 0 200 120" width="260" height="156" style="animation: float 4s ease-in-out infinite;">
            <ellipse cx="100" cy="65" rx="85" ry="38" fill="#5bbbd4" />
            <ellipse cx="106" cy="76" rx="58" ry="20" fill="#d8eff6" />
            <polygon points="118,25 148,62 90,62" fill="#3d9dbc" />
            <polygon points="82,76 52,102 88,82" fill="#3d9dbc" />
            <polygon points="18,48 2,25 32,60" fill="#3d9dbc" />
            <polygon points="18,75 2,95 32,60" fill="#3d9dbc" />
            <circle cx="158" cy="58" r="7" fill="#1a1a2e" />
            <circle cx="160" cy="55.5" r="2.5" fill="white" />
            <path d="M 146 70 Q 157 79 168 70" fill="none" stroke="#1a1a2e" stroke-width="2.5" stroke-linecap="round" />
            <path d="M 138 60 Q 141 68 138 76" fill="none" stroke="rgba(61,157,188,0.7)" stroke-width="1.5" />
            <ellipse cx="177" cy="64" rx="10" ry="7" fill="#6dcee5" opacity="0.6" />
          </svg>
          <div class="blaahaj-text">blГҐhaj-certified dev рџЏіпёЏвЂЌвљ§пёЏрџ¦€</div>
        </div>
        
        <div class="terminal-container">
          <div class="terminal-window">
            <div class="term-line"><span class="term-prompt">$</span> whoami</div>
            <div class="term-line"><span class="term-green">{profile.name.toLowerCase().replace(' ', '_')}</span></div>
            <div class="term-line"><span class="term-prompt">$</span> stack --list</div>
            <div class="term-line"><span class="term-cyan">{profile.hero_tags.map(t => t.toLowerCase()).join(' ')}</span></div>
            <div class="term-line"><span class="term-prompt">$</span> status</div>
            <div class="term-line"><span class="term-accent-alt">{profile.about_status} рџџў</span></div>
          </div>
        </div>
        
        <div class="hero-bg-text">гѓўгѓђг‚¤гѓ«<br />й–‹з™єиЂ…</div>
      </div>
    </div>
    
    <div class="scroll-indicator">
      <span>scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <section id="about" class="section-surface">
    <div class="container">
      <div class="section-header">
        <div class="section-num">01 / About</div>
        <h2 class="section-title">{profile.about_title_1}<br /><span class="text-accent">{profile.about_title_2}</span></h2>
      </div>
      <div class="about-grid">
        <div>
          <p class="about-desc">{profile.about_paragraph_1}</p>
          <p class="about-desc">{profile.about_paragraph_2}</p>
          <div class="about-status">
            <span class="text-accent">$</span> {profile.about_status}
          </div>
        </div>
        <div>
          <div class="stack-title">Stack</div>
          <div class="badges-wrap">
            {skills.map(s => {
              const bg = getTechColor(s);
              return <span class="tech-badge" style={`--badge-color: ${bg};`}>{s}</span>
            })}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="projects" class="section-bg">
    <div class="container">
      <div class="section-header">
        <div class="section-num">02 / Projects</div>
        <h2 class="section-title">Things I've built</h2>
      </div>
      
      <div class="filter-wrap" id="project-filters">
        {ALL_FILTERS.map((t, idx) => (
          <button class={`filter-btn ${idx === 0 ? 'active' : ''}`} data-filter={t}>
            {FILTER_ICONS[t] && <i class={`${FILTER_ICONS[t]} filter-icon`}></i>}{t}
          </button>
        ))}
      </div>
      
      <div class="projects-grid" id="projects-grid">
        {projects.map(p => {
          return (
            <a href={`/projects/${p.id}`} class="project-card" data-tech={p.data.tech.join(',')}>
              <div class="project-card-highlight"></div>
              <div class="project-emoji">
                {p.data.image
                  ? <Image src={p.data.image} alt="" inferSize={true} loading="lazy" decoding="async" />
                  : p.data.emoji}
              </div>
              <h3 class="project-name">{p.data.name}</h3>
              <p class="project-desc">{p.data.description}</p>
              <div class="badges-wrap">
                {p.data.tech.map((t) => {
                  const bg = getTechColor(t);
                  return <span class="tech-badge" style={`--badge-color: ${bg};`}>{t}</span>
                })}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section id="case-studies" class="section-surface">
    <div class="container">
      <div class="case-study-header-wrap">
        <div class="portal-ring">
          <div class="portal-inner"></div>
        </div>
        <div class="section-header" style="margin-bottom: 0;">
          <div class="section-num">03 / Case Studies</div>
          <h2 class="section-title">How I think<br /><span class="text-accent">at scale</span></h2>
        </div>
      </div>
      
      <div class="case-studies-wrap">
        {CASE_STUDIES.map((cs) => (
          <div class="case-study-card">
            <details>
              <summary>
                <div class="cs-summary-content">
                  <div class="cs-category">{cs.category}</div>
                  <h3 class="cs-title">{cs.title}</h3>
                  <p class="cs-desc">{cs.summary}</p>
                </div>
                <div class="cs-arrow">в†“</div>
              </summary>
              <div class="cs-details">
                {cs.sections.map((sec, i) => (
                  <div class="cs-section" style={i < cs.sections.length - 1 ? "margin-bottom: 20px;" : ""}>
                    <h4 class="cs-sec-title">{sec.title}</h4>
                    <p class="cs-sec-content">{sec.content}</p>
                  </div>
                ))}
                <div class="badges-wrap" style="margin-top: 20px;">
                  {cs.tech.map((t) => {
                    const bg = getTechColor(t);
                    return <span class="tech-badge" style={`--badge-color: ${bg};`}>{t}</span>
                  })}
                </div>
              </div>
            </details>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="blog" class="section-bg">
    <div class="container">
      <div class="section-header">
        <div class="section-num">04 / Writing</div>
        <h2 class="section-title">Blog</h2>
      </div>
      <div class="blog-grid">
        {blogPosts.map(post => (
          <a href={`/blog/${post.id}/`} class="blog-card">
            {post.data.img && <img src={post.data.img} alt="" loading="lazy" decoding="async" class="blog-card-img" onerror="if(!this.dataset.f){this.dataset.f='1';this.src='/blog/fallback.svg';}" />}
            <div class="blog-meta">{fmtDate(post.data.date)} В· {post.data.author}</div>
            <h3 class="blog-title">{post.data.title}</h3>
            {post.data.description && <p class="blog-excerpt">{post.data.description}</p>}
            <div class="badges-wrap">
              {post.data.tags.map((t) => (
                <span class="blog-tag">#{t}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
      <div style="margin-top: 28px; text-align: center;">
        <a href="/blog/" class="btn-secondary">Read all posts в†’</a>
      </div>
    </div>
  </section>

  <section id="resume" class="section-surface">
    <div class="container">
      <div class="resume-header-wrap">
        <div class="section-header" style="margin-bottom: 0;">
          <div class="section-num">05 / Experience</div>
          <h2 class="section-title">Career</h2>
        </div>
        <a href={CV_URL} class="btn-download" {...CV_URL !== '#' ? { download: true, target: '_blank', rel: 'noopener noreferrer' } : {}}>в†“ Download CV</a>
      </div>
      
      <div class="timeline-wrap">
        {EXPERIENCE.map((item, i) => (
          <div class="timeline-item">
            <div class="timeline-marker-wrap">
              <div class="timeline-marker"></div>
              {i < EXPERIENCE.length - 1 && <div class="timeline-line"></div>}
            </div>
            <div class="timeline-content" style={i < EXPERIENCE.length - 1 ? "padding-bottom: 36px;" : ""}>
              <div class="timeline-period">{item.period}</div>
              <div class="timeline-role">{item.role}</div>
              <div class="timeline-company">
                {item.logo && <img src={item.logo} alt={item.company} loading="lazy" decoding="async" class="company-logo" />}
                {item.url ? <a href={item.url} class="company-link" target="_blank" rel="noopener noreferrer">{item.company}</a> : item.company}
              </div>
              <p class="timeline-desc">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="contact" class="section-bg">
    <div class="container" style="text-align: center;">
      <div class="section-header">
        <div class="section-num">06 / Contact</div>
        <h2 class="section-title">Let's build<br /><span class="text-accent">something.</span></h2>
      </div>
      <p class="contact-desc">
        Open to senior mobile / platform infra roles. Also happy to chat KMP, Rust,
        or which Valve game is the best (it's Portal 2).
      </p>
      <div class="contact-links">
        {links.map(l => (
          <a href={l.href} class="contact-link">
            {l.icon ? <l.icon/> : l.pre}
            {l.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="footer-content">
      <div class="footer-left">
        <div class="footer-blaahaj">
          <svg viewBox="0 0 200 120" width="44" height="26.4" style="animation: float 4s ease-in-out infinite;">
            <ellipse cx="100" cy="65" rx="85" ry="38" fill="#5bbbd4" />
            <ellipse cx="106" cy="76" rx="58" ry="20" fill="#d8eff6" />
            <polygon points="118,25 148,62 90,62" fill="#3d9dbc" />
            <polygon points="82,76 52,102 88,82" fill="#3d9dbc" />
            <polygon points="18,48 2,25 32,60" fill="#3d9dbc" />
            <polygon points="18,75 2,95 32,60" fill="#3d9dbc" />
            <circle cx="158" cy="58" r="7" fill="#1a1a2e" />
            <circle cx="160" cy="55.5" r="2.5" fill="white" />
            <path d="M 146 70 Q 157 79 168 70" fill="none" stroke="#1a1a2e" stroke-width="2.5" stroke-linecap="round" />
            <path d="M 138 60 Q 141 68 138 76" fill="none" stroke="rgba(61,157,188,0.7)" stroke-width="1.5" />
            <ellipse cx="177" cy="64" rx="10" ry="7" fill="#6dcee5" opacity="0.6" />
          </svg>
        </div>
        <span class="footer-text">made with love &amp; blГҐhaj рџЏіпёЏвЂЌвљ§пёЏ</span>
      </div>
      <span class="footer-text">В© 2026 Luisa Martins</span>
    </div>
  </footer>
</Layout>

<style>
  .navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 100; transition: all 0.4s ease; background: transparent; border-bottom: 1px solid transparent; }
  .navbar.scrolled { background: color-mix(in srgb, var(--theme-bg) 95%, transparent); backdrop-filter: blur(16px); border-bottom-color: var(--theme-border); }
  .nav-gradient { height: 5px; background: linear-gradient(90deg,#55CDFC 20%,#F7A8B8 20% 40%,#FFFFFF 40% 60%,#F7A8B8 60% 80%,#55CDFC 80%); }
  .nav-content { max-width: 1200px; margin: 0 auto; padding: 0 32px; display: flex; align-items: center; height: 58px; gap: 16px; }
  .nav-links { margin-left: auto; }
  .nav-right { display: flex; align-items: center; gap: 12px; }
  .nav-toggle { display: none; background: transparent; border: 1px solid var(--theme-border); border-radius: 8px; width: 36px; height: 36px; cursor: pointer; padding: 0; flex-direction: column; align-items: center; justify-content: center; gap: 4px; }
  .nav-toggle span { display: block; width: 16px; height: 2px; background: var(--theme-accent); border-radius: 1px; transition: transform 0.25s ease, opacity 0.25s ease; }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
  .nav-logo { font-family: 'Space Mono', monospace; font-size: 15px; font-weight: 700; color: var(--theme-accent); text-decoration: none; letter-spacing: -0.02em; }
  .nav-links { display: flex; gap: 28px; }
  .nav-link { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--theme-text-muted); text-decoration: none; letter-spacing: 0.1em; transition: color 0.2s; }
  .nav-link:hover { color: var(--theme-accent); }

  .hero-section { min-height: 100vh; position: relative; display: flex; align-items: center; overflow: hidden; background: var(--theme-bg); }
  .hero-grid-bg { position: absolute; bottom: 0; left: 0; right: 0; height: 46%; background-image: linear-gradient(var(--theme-grid-color) 1px, transparent 1px), linear-gradient(90deg, var(--theme-grid-color) 1px, transparent 1px); background-size: 60px 60px; transform: perspective(420px) rotateX(62deg); transform-origin: bottom; -webkit-mask-image: linear-gradient(to top, black 0%, transparent 100%); mask-image: linear-gradient(to top, black 0%, transparent 100%); }
  .hero-sun-container { position: absolute; bottom: 37%; left: 50%; transform: translateX(-50%); width: 320px; height: 160px; overflow: hidden; animation: sunrisePulse 3s ease-in-out infinite; }
  .hero-sun { position: absolute; inset: 0; border-radius: 320px 320px 0 0; background: linear-gradient(to bottom, var(--theme-sun-0), var(--theme-sun-1) 50%, var(--theme-sun-2)); }
  .hero-sun-line { position: absolute; left: 0; right: 0; background: var(--theme-bg); }
  .hero-overlay { position: absolute; inset: 0; pointer-events: none; z-index: 1; background-image: repeating-linear-gradient(0deg,rgba(0,0,0,0.04) 0px,rgba(0,0,0,0.04) 1px,transparent 1px,transparent 4px); }
  .hero-content { position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 0 32px; width: 100%; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; padding-top: 80px; animation: fadeUp 1s ease forwards; }
  .hero-subtitle { font-family: 'Space Mono', monospace; font-size: 12px; color: var(--theme-accent-alt); letter-spacing: 0.22em; text-transform: uppercase; margin-bottom: 16px; }
  .hero-title { font-family: 'Space Grotesk', sans-serif; font-weight: 800; font-size: clamp(44px, 7.5vw, 100px); line-height: 0.95; color: var(--theme-text); margin-bottom: 24px; letter-spacing: -0.03em; text-shadow: 0 0 60px color-mix(in srgb, var(--theme-accent) 30%, transparent); }
  .hero-desc { font-family: 'DM Sans', sans-serif; font-size: 16px; color: var(--theme-text-muted); line-height: 1.8; max-width: 460px; margin-bottom: 28px; }
  .hero-badges { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 32px; }
  .hero-actions { display: flex; gap: 12px; }
  .btn-primary { padding: 13px 28px; border-radius: 12px; background: var(--theme-accent); color: var(--theme-bg); font-family: 'Space Mono', monospace; font-weight: 700; font-size: 12px; text-decoration: none; letter-spacing: 0.06em; transition: all 0.2s; box-shadow: var(--theme-glow); }
  .btn-primary:hover { transform: translateY(-2px); }
  .btn-secondary { padding: 13px 28px; border-radius: 12px; border: 1px solid var(--theme-border); color: var(--theme-text); font-family: 'Space Mono', monospace; font-weight: 700; font-size: 12px; text-decoration: none; letter-spacing: 0.06em; transition: all 0.2s; background: transparent; }
  .btn-secondary:hover { border-color: var(--theme-accent); color: var(--theme-accent); }

  .hero-right { display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; gap: 10px; }
  .hero-bg-text { position: absolute; top: 0; right: -8px; font-family: 'Space Mono', monospace; font-size: 44px; color: color-mix(in srgb, var(--theme-accent) 12%, transparent); line-height: 1.25; user-select: none; font-weight: 700; pointer-events: none; }

  .blaahaj-container { display: block; }
  .terminal-container { display: block; }

  .blaahaj-text { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--theme-text-muted); letter-spacing: 0.08em; text-align: center; }
  .terminal-window { background: var(--theme-surface); border: 1px solid var(--theme-border); border-radius: 16px; padding: 2em 8em 4em 2em; width: 100%; max-width: 400px; font-family: 'Space Mono', monospace; font-size: 13px; line-height: 2; color: var(--theme-text-muted); }
  .term-prompt { color: var(--theme-accent); }
  .term-green { color: var(--theme-green); }
  .term-cyan { color: var(--theme-cyan); }
  .term-accent-alt { color: var(--theme-accent-alt); }

