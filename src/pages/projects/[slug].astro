---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={`${project.data.name} — Luisa Martins`}>
  <div style="background: var(--theme-bg); min-height: 100vh; padding: 100px 32px;">
    <div style="max-width: 800px; margin: 0 auto; background: var(--theme-surface); border: 1px solid var(--theme-border); border-radius: 16px; padding: 40px; color: var(--theme-text); font-family: 'DM Sans', sans-serif;">
      
      <a href="/" style="color: var(--theme-accent); text-decoration: none; font-family: 'Space Mono', monospace; font-size: 14px; margin-bottom: 32px; display: inline-block;">
        ← Back to Portfolio
      </a>

      <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px;">
        {project.data.image ? (
          <img src={project.data.image} alt={`${project.data.name} logo`} style="width: 48px; height: 48px; object-fit: contain;" />
        ) : (
          <span style="font-size: 48px;">{project.data.emoji}</span>
        )}
        <h1 style="font-family: 'Space Grotesk', sans-serif; font-weight: 800; font-size: clamp(32px, 5vw, 48px); margin: 0;">
          {project.data.name}
        </h1>
      </div>

      <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 32px;">
        {project.data.tech.map(t => (
          <span style="display: inline-flex; align-items: center; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-family: 'Space Mono', monospace; font-weight: 700; background: color-mix(in srgb, var(--theme-accent) 15%, transparent); color: var(--theme-accent); border: 1px solid color-mix(in srgb, var(--theme-accent) 30%, transparent); letter-spacing: 0.05em; white-space: nowrap;">
            {t}
          </span>
        ))}
      </div>

      <p style="font-size: 16px; line-height: 1.8; color: var(--theme-text-muted); margin-bottom: 40px;">
        {project.data.description}
      </p>

      {project.data.github !== '#' && (
        <a href={project.data.github} target="_blank" rel="noopener noreferrer" style="display: inline-block; padding: 12px 24px; border-radius: 12px; background: var(--theme-accent); color: var(--theme-bg); font-family: 'Space Mono', monospace; font-weight: 700; font-size: 14px; text-decoration: none; letter-spacing: 0.06em; margin-bottom: 48px;">
          View on GitHub ↗
        </a>
      )}

      <div class="project-content">
        <Content />
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .project-content h2, .project-content h3 {
    font-family: 'Space Grotesk', sans-serif;
    color: var(--theme-text);
    margin-top: 2em;
    margin-bottom: 1em;
  }
  .project-content p {
    line-height: 1.8;
    color: var(--theme-text-muted);
    margin-bottom: 1.5em;
  }
  .project-content ul {
    color: var(--theme-text-muted);
    margin-bottom: 1.5em;
    padding-left: 20px;
  }
  .project-content li {
    margin-bottom: 0.5em;
  }
  .project-content img {
    max-width: 100%;
    border-radius: 12px;
    border: 1px solid var(--theme-border);
    margin: 2em 0;
  }
  .project-content img[src*="screenshot"],
  .project-content img[src*="demo"] {
    max-width: 320px;
    display: block;
  }
  .project-content strong {
    color: var(--theme-text);
  }
  .project-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5em;
    font-size: 14px;
  }
  .project-content th, .project-content td {
    text-align: left;
    padding: 10px 16px;
    border: 1px solid var(--theme-border);
    color: var(--theme-text-muted);
  }
  .project-content th {
    background: color-mix(in srgb, var(--theme-accent) 8%, transparent);
    color: var(--theme-text);
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
  }
  .project-content tr:nth-child(even) td {
    background: color-mix(in srgb, var(--theme-surface) 50%, transparent);
  }
</style>
