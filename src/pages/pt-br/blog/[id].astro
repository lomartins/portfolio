---
import Layout from '../../../layouts/Layout.astro';
import BlogPost from '../../../components/BlogPost.astro';
import { getCollection } from 'astro:content';

const LANG = 'pt-br' as const;

export async function getStaticPaths() {
  const posts = await getCollection('blog', (p) => p.id.startsWith('pt-br/'));
  return posts.map(post => ({
    params: { id: post.id.replace(/^pt-br\//, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<Layout title={`${post.data.title} — Luisa Martins`} lang={LANG}>
  <BlogPost lang={LANG} pathname={Astro.url.pathname} post={post} />
</Layout>
