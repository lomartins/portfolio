---
import Layout from '../../layouts/Layout.astro';
import PortfolioHome from '../../components/PortfolioHome.astro';
import { getCollection } from 'astro:content';

const lang = 'pt-br' as const;
const profile = (await getCollection('profile', (p) => p.id.startsWith(`${lang}/`) || p.id === lang))[0]!.data;
---

<Layout title={`${profile.name} — ${profile.hero_title}`} lang={lang}>
  <PortfolioHome lang={lang} pathname={Astro.url.pathname} />
</Layout>
