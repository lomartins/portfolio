---
import Layout from '../../../layouts/Layout.astro';
import ProjectDetail from '../../../components/ProjectDetail.astro';
import { getCollection } from 'astro:content';

const LANG = 'pt-br' as const;

export async function getStaticPaths() {
  const projects = await getCollection('projects', (p) => p.id.startsWith('pt-br/'));
  return projects.map(project => ({
    params: { slug: project.id.replace(/^pt-br\//, '') },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.data.name} — Luisa Martins`} lang={LANG}>
  <ProjectDetail lang={LANG} pathname={Astro.url.pathname} project={project} />
</Layout>
